{
  "name": "the-campfire",
  "version": "0.3.1",
  "type": "module",
  "description": "Campfire \u2014 collaborative web platform for AI coding agents. Run Claude Code, Codex, Goose, Aider, and more from one browser UI with real-time collaboration, permission voting, and automation.",
  "license": "MIT",
  "author": "The Vibe Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stretchcloud/campfire.git",
    "directory": "web"
  },
  "homepage": "https://github.com/stretchcloud/campfire#readme",
  "bugs": {
    "url": "https://github.com/stretchcloud/campfire/issues"
  },
  "bin": {
    "the-campfire": "./bin/cli.ts"
  },
  "files": [
    "bin/",
    "server/",
    "dist/",
    "!server/**/*.test.ts",
    "!server/protocol/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "ai",
    "agent",
    "multi-agent",
    "self-hosted",
    "mcp",
    "web-ui",
    "vibe-coding"
  ],
  "scripts": {
    "dev": "bun dev.ts",
    "dev:api": "bun --watch server/index.ts",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "prepublishOnly": "cp ../README.md ../LICENSE . && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:codex-contract": "vitest run server/codex-protocol-*.test.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@monaco-editor/react": "^4.7.0",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "geist": "^1.7.0",
    "hono": "^4.7.0",
    "mermaid": "^11.12.3",
    "posthog-js": "^1.347.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.5",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vitest": "^4.0.18",
    "zustand": "^5.0.0"
  }
}
